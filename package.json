{
  "name": "quant-dashboard",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "React 19 SPA for the quant trading system — portfolio performance, equity curves, and strategy details, fed by quant-api-gateway over REST.",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "lint": "biome lint ./src",
    "lint:fix": "biome lint --write ./src",
    "format": "biome format ./src",
    "format:fix": "biome format --write ./src",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "quality": "pnpm lint && pnpm format && pnpm typecheck && pnpm test:coverage",
    "prepare": "husky"
  },
  "dependencies": {
    "@tanstack/react-query": "^5.100.10",
    "@tanstack/react-virtual": "^3.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-router-dom": "^7.15.1",
    "recharts": "^3.8.1",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.0",
    "@tailwindcss/vite": "^4.3.0",
    "@testing-library/jest-dom": "^6.6.0",
    "@testing-library/react": "^16.0.0",
    "@testing-library/user-event": "^14.5.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.0",
    "@vitest/coverage-v8": "^3.0.0",
    "husky": "^9.1.0",
    "jsdom": "^26.0.0",
    "lint-staged": "^15.2.0",
    "msw": "^2",
    "tailwindcss": "^4.3.0",
    "typescript": "^5.6.0",
    "vite": "^6.0.0",
    "vitest": "^3.0.0"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "biome lint --write",
      "biome format --write"
    ]
  },
  "packageManager": "pnpm@9.15.0",
  "engines": {
    "node": ">=20"
  }
}
