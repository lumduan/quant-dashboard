# App
VITE_APP_NAME=quant-dashboard
VITE_APP_VERSION=0.1.0

# API Gateway — used by Vite dev proxy and nginx reverse proxy.
# Change this to point at a different gateway without rebuilding the image.
#
# Pick the value that matches how you're running the dashboard:
#   * Local dev (`pnpm dev`): use a host-reachable address, e.g.
#       API_UPSTREAM=http://localhost:8080
#   * Docker (`docker compose up`): use the gateway's service name on
#     `quant-network` (NOT `localhost` — inside the container that is
#     the dashboard itself), e.g.
#       API_UPSTREAM=http://quant-api-gateway:8000
API_UPSTREAM=http://quant-api-gateway:8000
VITE_API_BASE_URL=http://localhost:8080
